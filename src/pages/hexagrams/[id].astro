            </li>
          ))}
        </ul>
      </section>
    )}

    </div>{/* /view-original */}
  </article>

  <script is:inline>
    (function () {
      const article = document.querySelector("article.hex");
      if (!article) return;
      const btns = article.querySelectorAll(".mt-btn");
      const stored = (() => {
        try { return localStorage.getItem("hex-mode"); } catch { return null; }
      })();
      if (stored === "original" || stored === "modern") {
        article.setAttribute("data-mode", stored);
        btns.forEach((b) => {
          const active = b.getAttribute("data-mode") === stored;
          b.classList.toggle("active", active);
          b.setAttribute("aria-selected", active ? "true" : "false");
        });
      }
      btns.forEach((b) => {
        b.addEventListener("click", () => {
          const mode = b.getAttribute("data-mode");
          if (!mode) return;
          article.setAttribute("data-mode", mode);
          btns.forEach((x) => {
            const active = x === b;
            x.classList.toggle("active", active);
            x.setAttribute("aria-selected", active ? "true" : "false");
          });
          try { localStorage.setItem("hex-mode", mode); } catch {}
        });
      });

      // Modern-view tabs
      const modernView = article.querySelector(".view-modern");
      if (modernView) {
        const tabs = modernView.querySelectorAll(".mr-tab");
        const panels = modernView.querySelectorAll(".mr-panel");
        const setTab = (name) => {
          modernView.setAttribute("data-tab", name);
          tabs.forEach((t) => {
            const active = t.getAttribute("data-tab") === name;
            t.classList.toggle("active", active);
            t.setAttribute("aria-selected", active ? "true" : "false");
          });
          panels.forEach((p) => {
            p.style.display = p.getAttribute("data-panel") === name ? "block" : "none";
          });
        };
        const storedTab = (() => {
          try { return localStorage.getItem("hex-tab"); } catch { return null; }
        })();
        const initialTab = (storedTab && modernView.querySelector(`[data-panel="${storedTab}"]`))
          ? storedTab
          : (modernView.getAttribute("data-tab") || "meaning");
        setTab(initialTab);
        tabs.forEach((t) => {
          t.addEventListener("click", () => {
            const name = t.getAttribute("data-tab");
            if (!name) return;
            setTab(name);
            try { localStorage.setItem("hex-tab", name); } catch {}
          });
        });
      }
    })();
  </script>
</Layout>

