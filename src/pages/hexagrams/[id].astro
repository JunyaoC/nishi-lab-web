              <ul class="nl">
                {gangByType[k].map((n) => (
                  <li>{n.content}{n.source && <span class="src">{n.source}</span>}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ─── 書本對照 · textbook parallels ─── */}
    {textbookNotes.length > 0 && (
      <section class="sec sec-muted">
        <h2 class="sec-h">書本對照 <span class="sec-sub">electronic textbook · parallel text</span></h2>
        <ul class="nl book">
          {textbookNotes.map((n) => (
            <li>
              <span class="book-k">{textbookLabels[n.note_type ?? ""] ?? n.note_type}</span>
              {n.content}
              {n.source && <span class="src">{n.source}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* ─── Dev: any unrouted notes (should be empty) ─── */}
    {unroutedNotes.length > 0 && (
      <section class="sec sec-debug">
        <h2 class="sec-h">未分類 <span class="sec-sub">unrouted — fix routing</span></h2>
